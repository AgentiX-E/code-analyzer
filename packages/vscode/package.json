{
  "name": "@code-analyzer/vscode",
  "displayName": "Code Analyzer",
  "version": "0.1.0",
  "description": "World-class code intelligence for VS Code — AI-powered code exploration, review, and analysis",
  "author": "Lambertyan",
  "license": "MIT",
  "keywords": ["code-analysis", "vscode-extension", "code-review", "knowledge-graph", "copilot-chat", "ai-assisted", "code-intelligence"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Lambertyan/code-analyzer.git",
    "directory": "packages/vscode"
  },
  "bugs": {
    "url": "https://github.com/Lambertyan/code-analyzer/issues"
  },
  "homepage": "https://github.com/Lambertyan/code-analyzer#readme",
  "qna": "https://github.com/Lambertyan/code-analyzer/discussions",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "files": ["dist"],
  "sideEffects": false,
  "publisher": "agentix",
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension/extension.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/extension/extension.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "code-analyzer",
        "name": "Code Analyzer",
        "description": "Explore, search, and review code with AI assistance"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "code-analyzer-sidebar",
          "title": "Code Analyzer",
          "icon": "$(search)"
        }
      ]
    },
    "views": {
      "code-analyzer-sidebar": [
        {
          "id": "code-analyzer.sidebar",
          "name": "Code Intelligence"
        },
        {
          "id": "code-analyzer.graphExplorer",
          "name": "Graph Explorer"
        },
        {
          "id": "code-analyzer.config",
          "name": "Configuration"
        }
      ]
    },
    "commands": [
      {
        "command": "code-analyzer.showSidebar",
        "title": "Show Code Analyzer"
      },
      {
        "command": "code-analyzer.analyze",
        "title": "Analyze Codebase"
      },
      {
        "command": "code-analyzer.review",
        "title": "Review Changes"
      },
      {
        "command": "code-analyzer.search",
        "title": "Search Codebase"
      },
      {
        "command": "code-analyzer.showConfig",
        "title": "Configure Code Analyzer"
      },
      {
        "command": "code-analyzer.config.focus",
        "title": "Focus Config View"
      },
      {
        "command": "code-analyzer.graphExplorer.focus",
        "title": "Focus Graph Explorer"
      },
      {
        "command": "code-analyzer.fixIssue",
        "title": "Fix Issue"
      },
      {
        "command": "code-analyzer.ignoreIssue",
        "title": "Ignore Issue"
      },
      {
        "command": "code-analyzer.explainIssue",
        "title": "Explain Issue"
      },
      {
        "command": "code-analyzer.findCallers",
        "title": "Find Callers"
      },
      {
        "command": "code-analyzer.findCallees",
        "title": "Find Callees"
      },
      {
        "command": "code-analyzer.traceImpact",
        "title": "Trace Impact"
      },
      {
        "command": "code-analyzer.showSymbolDetail",
        "title": "Show Symbol Details"
      }
    ],
    "configuration": {
      "title": "Code Analyzer",
      "properties": {
        "codeAnalyzer.autoIndex": {
          "type": "boolean",
          "default": true,
          "description": "Auto-index on project open"
        },
        "codeAnalyzer.indexMode": {
          "type": "string",
          "default": "full",
          "enum": ["full", "moderate", "fast"],
          "description": "Index depth"
        },
        "codeAnalyzer.maxFileSize": {
          "type": "number",
          "default": 10485760,
          "description": "Max file size in bytes"
        },
        "codeAnalyzer.excludePatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["node_modules/**", "dist/**", ".git/**", "build/**"],
          "description": "File patterns to exclude from analysis"
        },
        "codeAnalyzer.reviewOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run code review automatically on save"
        },
        "codeAnalyzer.showInlineDecorations": {
          "type": "boolean",
          "default": true,
          "description": "Display review comments as inline decorations"
        },
        "codeAnalyzer.maxSearchResults": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum number of search results"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "code-analyzer.analyze",
          "when": "view == code-analyzer.sidebar",
          "group": "navigation"
        },
        {
          "command": "code-analyzer.review",
          "when": "view == code-analyzer.sidebar",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "code-analyzer.findCallers",
          "when": "viewItem == symbol",
          "group": "navigation"
        },
        {
          "command": "code-analyzer.findCallees",
          "when": "viewItem == symbol",
          "group": "navigation"
        },
        {
          "command": "code-analyzer.traceImpact",
          "when": "viewItem == symbol",
          "group": "navigation"
        },
        {
          "command": "code-analyzer.showSymbolDetail",
          "when": "viewItem == symbol",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "code-analyzer.analyze",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "code-analyzer.review",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      },
      {
        "command": "code-analyzer.search",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "!searchInputFocus"
      },
      {
        "command": "code-analyzer.showSidebar",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "!sideBarFocus"
      }
    ]
  },
  "dependencies": {
    "@code-analyzer/shared": "workspace:*",
    "@code-analyzer/analyzer": "workspace:*",
    "@code-analyzer/intelligence": "workspace:*",
    "@code-analyzer/infra": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
