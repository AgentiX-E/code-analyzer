{
  "name": "@code-analyzer/vscode",
  "version": "0.1.0",
  "description": "VS Code extension for Code Analyzer",
  "author": "Lambertyan",
  "license": "MIT",
  "main": "./dist/extension.js",
  "types": "./dist/extension.d.ts",
  "exports": {
    ".": {
      "import": "./dist/extension.js",
      "types": "./dist/extension.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@code-analyzer/shared": "workspace:*",
    "@code-analyzer/core": "workspace:*",
    "@code-analyzer/analyzer": "workspace:*",
    "@code-analyzer/intelligence": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
