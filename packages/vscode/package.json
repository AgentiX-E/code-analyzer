{
  "name": "@code-analyzer/vscode",
  "displayName": "Code Analyzer",
  "version": "0.1.0",
  "description": "World-class code intelligence for VS Code — AI-powered code exploration, review, and analysis",
  "author": "Lambertyan",
  "license": "MIT",
  "keywords": ["code-analysis", "vscode-extension", "code-review", "knowledge-graph", "copilot-chat", "ai-assisted", "code-intelligence"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Lambertyan/code-analyzer.git",
    "directory": "packages/vscode"
  },
  "bugs": {
    "url": "https://github.com/Lambertyan/code-analyzer/issues"
  },
  "homepage": "https://github.com/Lambertyan/code-analyzer#readme",
  "qna": "https://github.com/Lambertyan/code-analyzer/discussions",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "files": ["dist"],
  "sideEffects": false,
  "publisher": "agentix",
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension/extension.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/extension/extension.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "code-analyzer",
        "name": "Code Analyzer",
        "description": "Explore, search, and review code with AI assistance"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "code-analyzer-sidebar",
          "title": "Code Analyzer",
          "icon": "$(search)"
        }
      ]
    },
    "views": {
      "code-analyzer-sidebar": [
        {
          "id": "code-analyzer.sidebar",
          "name": "Code Intelligence"
        }
      ]
    },
    "commands": [
      {
        "command": "code-analyzer.showSidebar",
        "title": "Show Code Analyzer"
      },
      {
        "command": "code-analyzer.analyze",
        "title": "Analyze Codebase"
      },
      {
        "command": "code-analyzer.review",
        "title": "Review Changes"
      },
      {
        "command": "code-analyzer.search",
        "title": "Search Codebase"
      },
      {
        "command": "code-analyzer.showConfig",
        "title": "Configure Code Analyzer"
      }
    ],
    "configuration": {
      "title": "Code Analyzer",
      "properties": {
        "codeAnalyzer.autoIndex": {
          "type": "boolean",
          "default": true,
          "description": "Auto-index on project open"
        },
        "codeAnalyzer.indexMode": {
          "type": "string",
          "default": "full",
          "enum": ["full", "moderate", "fast"],
          "description": "Index depth"
        },
        "codeAnalyzer.maxFileSize": {
          "type": "number",
          "default": 10485760,
          "description": "Max file size in bytes"
        }
      }
    }
  },
  "dependencies": {
    "@code-analyzer/shared": "workspace:*",
    "@code-analyzer/analyzer": "workspace:*",
    "@code-analyzer/intelligence": "workspace:*",
    "@code-analyzer/infra": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
