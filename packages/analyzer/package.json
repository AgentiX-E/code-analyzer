{
  "name": "@code-analyzer/analyzer",
  "version": "0.1.0",
  "description": "Code analysis engine for Code Analyzer",
  "author": "Lambertyan",
  "license": "MIT",
  "keywords": ["code-analysis", "static-analysis", "ast", "tree-sitter", "scope-resolution", "unified-parser", "code-intelligence"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Lambertyan/code-analyzer.git",
    "directory": "packages/analyzer"
  },
  "bugs": {
    "url": "https://github.com/Lambertyan/code-analyzer/issues"
  },
  "homepage": "https://github.com/Lambertyan/code-analyzer#readme",
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@code-analyzer/shared": "workspace:*",
    "@code-analyzer/core": "workspace:*",
    "@code-analyzer/infra": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
